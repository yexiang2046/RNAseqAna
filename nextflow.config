profiles {
  local {
    process.executor = 'local'
    process.docker = true
    process.container = 'xiang2019/rnaseq_cmd:v1.0.0'
  }
  awsbatch {
    process.executor = 'awsbatch'
    process.queue = 'rnaseq'
    process.memory = 64000.MB
    process.time = '1d'
    process.cpus = 8
    process.maxForks = 2
    process.docker = true
  }
  slurm {
    process.executor = 'slurm'
  }
}